# Codex CLI 配置模板
# 复制为 config.toml 并填入实际值，将 data/codex/ 挂载到容器 /app/codex_config/

model_provider = "azure"
model = "gpt-5.5"
model_reasoning_effort = "medium"

[model_providers.azure]
name = "Azure"
base_url = "https://<your-resource>.openai.azure.com/openai/v1"
env_key = "OPENAI_API_KEY"
wire_api = "responses"
request_max_retries = 3
stream_max_retries = 5
stream_idle_timeout_ms = 300000

# ── Hooks ────────────────────────────────────────────────────────────────────
[[hooks.PreToolUse]]
matcher = "^Bash$"

[[hooks.PreToolUse.hooks]]
type = "command"
command = "python3 /app/codex_hooks/pre_tool_use.py"
timeout = 30
statusMessage = "Checking Bash command"

[[hooks.PostToolUse]]
matcher = "^Bash$"

[[hooks.PostToolUse.hooks]]
type = "command"
command = "python3 /app/codex_hooks/post_tool_use.py"
timeout = 30
statusMessage = "Auditing Bash output"
