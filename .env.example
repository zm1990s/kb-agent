# ── 数据库 ───────────────────────────────────────────────
DATABASE_URL=

# ── 认证 ─────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE_MIN=
# 注册域名白名单已迁到数据库（allowed_domains 表），由管理员在应用内维护。
# 新部署时白名单为空 = 全拒绝注册；首个管理员登录后添加域名，其他人方可注册。

# 首个管理员（启动时幂等种子创建；密码 bcrypt 存库，可后续自行修改）
# 留空则不创建。生产务必用强密码。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Agent 引擎（唯一 LLM 出口）─────────────────────────────
ENGINE_BACKEND=claude_cli
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=
ENGINE_TIMEOUT_SEC=120

# Claude CLI 认证凭据（按你的实际方式填其一；未用到的留空/删除）
# 方式一：Anthropic API key
ANTHROPIC_API_KEY=
# 方式二：公司网关（自定义 base_url + token）
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
# 方式三：AWS Bedrock（设为 1 启用，并配 AWS 凭据）
CLAUDE_CODE_USE_BEDROCK=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=

# ── 存储（MVP 本地文件系统）────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=
# 下载链接有效期（秒）
DOWNLOAD_URL_TTL_SEC=

# ── 邮件通知（SMTP）─────────────────────────────────────────
# 留空则禁用邮件发送；可使用 Mailtrap / Gmail / 企业邮服等
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# SMTP_TLS=true  # 是否使用 STARTTLS（默认 true）
