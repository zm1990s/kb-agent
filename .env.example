# ── 数据库 ───────────────────────────────────────────────
DATABASE_URL=

# ── 认证 ─────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE_MIN=
# 注册域名白名单，逗号分隔，如 company.com,partner-a.com
# 注意：完整域名相等匹配，不使用 endswith
ALLOWED_EMAIL_DOMAINS=

# 首个管理员（启动时幂等种子创建；密码 bcrypt 存库，可后续自行修改）
# 留空则不创建。生产务必用强密码。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Agent 引擎（唯一 LLM 出口）─────────────────────────────
ENGINE_BACKEND=claude_cli
CLAUDE_CLI_PATH=
CLAUDE_MODEL=
ENGINE_TIMEOUT_SEC=

# ── 存储（MVP 本地文件系统）────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=
# 下载链接有效期（秒）
DOWNLOAD_URL_TTL_SEC=
