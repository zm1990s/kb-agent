# ── 数据库 ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kbagent:kbagent@postgres:5432/kbagent

# ── 认证 ─────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE_MIN=

# 首个管理员（留空则不创建，生产务必用强密码）
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Agent 引擎 ────────────────────────────────────────────
ENGINE_BACKEND=claude_cli
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=
# 空闲超时：连续无输出超过该秒数才终止 CLI（非总时长）
ENGINE_IDLE_TIMEOUT_SEC=60

# Claude CLI 认证（按实际方式填其一，其余留空）
# 方式一：Anthropic API key
ANTHROPIC_API_KEY=
# 方式二：自定义网关
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
# 方式三：AWS Bedrock
CLAUDE_CODE_USE_BEDROCK=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=

# ── 存储 ──────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=
DOWNLOAD_URL_TTL_SEC=

# ── 邮件通知（SMTP，留空则禁用）─────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
