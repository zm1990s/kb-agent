# ── 数据库 ───────────────────────────────────────────────
DATABASE_URL=

# ── 认证 ─────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE_MIN=
# 注册域名白名单已迁到数据库（allowed_domains 表），由管理员在应用内维护。
# 新部署时白名单为空 = 全拒绝注册；首个管理员登录后添加域名，其他人方可注册。

# 首个管理员（启动时幂等种子创建；密码 bcrypt 存库，可后续自行修改）
# 留空则不创建。生产务必用强密码。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Agent 引擎（唯一 LLM 出口）─────────────────────────────
ENGINE_BACKEND=claude_cli
CLAUDE_CLI_PATH=
CLAUDE_MODEL=
ENGINE_TIMEOUT_SEC=

# ── 存储（MVP 本地文件系统）────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=
# 下载链接有效期（秒）
DOWNLOAD_URL_TTL_SEC=
